---
import "../styles/global.css";
import { getOptionalUser } from "../lib/auth-helpers";
import { getLocale, getOtherLocale, t } from "../i18n";
import en from "../i18n/en.json";
import de from "../i18n/de.json";

interface Props {
    hideHeaderActions?: boolean;
    hideHomeLink?: boolean;
}

const { hideHeaderActions = false, hideHomeLink = false } = Astro.props;

const currentUser = await getOptionalUser(
    Astro.cookies,
    Astro.request.headers.get("Cookie") ?? "",
);
const isAccountPage = Astro.url.pathname === "/account";
const isFilemanagerPage = Astro.url.pathname === "/filemanager";
const isSessionsPage = Astro.url.pathname === "/sessions";

const locale = getLocale(Astro.cookies, Astro.request.headers.get('Accept-Language'));
const otherLocale = getOtherLocale(locale);
const flagSrc = otherLocale === 'de' ? '/flag-de.svg' : '/flag-en.svg';
const flagAlt = otherLocale === 'de' ? 'Deutsch' : 'English';
const i18nData = JSON.stringify({ en, de });
---

<html lang={locale}>
<head>
    <meta charset="utf-8"/>
    <link rel="icon" type="image/png" href="/favicon.png"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="description" content="HoloSpaceXR – Redesigning hybrid collaboration through XR technologies."/>
    <meta name="generator" content={Astro.generator}/>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap"/>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <title>HoloSpace-XR</title>
</head>
<body>
    {!hideHomeLink && (
        <div class="home-bar">
            <a href="/" class="home-link" aria-label={t(locale, 'nav_home')} title={t(locale, 'nav_home')} data-i18n-title="nav_home">
                <img src="/logos/hsxr_logo.png" alt="HoloSpaceXR" class="home-logo" />
            </a>
            <button type="button" class="locale-btn" aria-label={flagAlt} title={flagAlt} data-locale={otherLocale}>
                <img src={flagSrc} alt={flagAlt} class="locale-flag" />
            </button>
        </div>
    )}
    <div class="header-actions">
        {!hideHeaderActions && currentUser && !isSessionsPage && (
            <a href="/sessions" class="filemanager-icon" aria-label={t(locale, 'nav_sessions')} title={t(locale, 'nav_sessions')} data-i18n-title="nav_sessions">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="3" y="3" width="7" height="7"/>
                    <rect x="14" y="3" width="7" height="7"/>
                    <rect x="3" y="14" width="7" height="7"/>
                    <line x1="14" y1="14" x2="14" y2="14.01"/>
                    <line x1="20" y1="14" x2="20" y2="14.01"/>
                    <line x1="14" y1="20" x2="14" y2="20.01"/>
                    <line x1="20" y1="20" x2="20" y2="20.01"/>
                    <line x1="17" y1="17" x2="17" y2="17.01"/>
                </svg>
            </a>
        )}
        {!hideHeaderActions && currentUser && !isFilemanagerPage && (
            <a href="/filemanager" class="filemanager-icon" aria-label={t(locale, 'nav_filemanager')} title={t(locale, 'nav_filemanager')} data-i18n-title="nav_filemanager">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                </svg>
            </a>
        )}
        {!hideHeaderActions && currentUser ? (
            <a
                href="/account"
                class={`account-link${isAccountPage ? " account-link-active" : ""}`}
                aria-label={t(locale, 'nav_account')}
                title={currentUser.display_name ?? t(locale, 'nav_account')}
                data-i18n-title="nav_account"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                <span class="account-link-name">{currentUser.display_name ?? t(locale, 'nav_account')}</span>
            </a>
        ) : (
            !hideHeaderActions && !isAccountPage && (
                <a href="/account" class="account-link account-link-login" aria-label={t(locale, 'nav_login')} title={t(locale, 'nav_login')} data-i18n-title="nav_login">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </a>
            )
        )}
    </div>
    <slot />
    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-logos">
                <img src="/logos/logo1.png" alt="Logo 1" class="footer-logo footer-logo-sm" />
                <a href="https://www.fh-dresden.eu/de/forschung/forschungsprojekte/validierungsprojekt-holospacexr/" target="_blank" rel="noopener noreferrer"><img src="/logos/logo2.png" alt="Fachhochschule Dresden" class="footer-logo footer-logo-sm" /></a>
                <a href="https://newworkdesignlab.org" target="_blank" rel="noopener noreferrer"><img src="/logos/logo3.png" alt="NewWorkDesignLab" class="footer-logo footer-logo-sm" style="transform: translateY(2px);" /></a>
            </div>
            <span class="footer-divider">|</span>
            <a href="/privacy" class="footer-details-link" data-i18n="privacy_policy">{t(locale, 'privacy_policy')}</a>
            <span class="footer-divider">|</span>
            <a href="https://www.fh-dresden.eu/de/impressum/" target="_blank" rel="noopener noreferrer" class="footer-details-link" data-i18n="legal_note">{t(locale, 'legal_note')}</a>
        </div>
    </footer>
    <script is:inline define:vars={{ i18nData, locale }}>
    window.__i18n = JSON.parse(i18nData);
    window.__locale = locale;

    function applyLocale(lang) {
        var dict = window.__i18n[lang];
        if (!dict) return;
        document.querySelectorAll('[data-i18n]').forEach(function(el) {
            var key = el.getAttribute('data-i18n');
            if (dict[key] !== undefined) {
                if (el.hasAttribute('data-i18n-html')) {
                    el.innerHTML = dict[key];
                } else {
                    el.textContent = dict[key];
                }
            }
        });
        // Update title/aria-label attributes
        document.querySelectorAll('[data-i18n-title]').forEach(function(el) {
            var key = el.getAttribute('data-i18n-title');
            if (dict[key] !== undefined) {
                el.setAttribute('title', dict[key]);
                el.setAttribute('aria-label', dict[key]);
            }
        });
        // Update form data-t-* attributes for contact form
        var form = document.getElementById('contact-form');
        if (form) {
            var map = {
                'tConsent': 'contact_error_consent',
                'tName': 'contact_error_name',
                'tEmail': 'contact_error_email',
                'tInvalid': 'contact_error_invalid',
                'tGeneric': 'contact_error_generic',
                'tNetwork': 'contact_error_network',
                'tSending': 'contact_sending',
                'tSubmit': 'contact_submit',
                'tDone': 'contact_done_text',
                'tExists': 'contact_done_exists'
            };
            for (var k in map) {
                if (dict[map[k]]) form.dataset[k] = dict[map[k]];
            }
        }
        document.documentElement.setAttribute('lang', lang);
        window.__locale = lang;
    }
    window.applyLocale = applyLocale;

    document.querySelector('.locale-btn')?.addEventListener('click', function() {
        var current = window.__locale;
        var next = current === 'en' ? 'de' : 'en';
        document.cookie = 'locale=' + next + ';path=/;max-age=31536000;SameSite=Lax';
        applyLocale(next);

        // Notify components that locale changed
        window.dispatchEvent(new CustomEvent('hsxr:locale-changed', { detail: { locale: next } }));

        // Update button to show the OTHER language flag
        var btn = this;
        var otherNext = next === 'en' ? 'de' : 'en';
        var flagImg = btn.querySelector('.locale-flag');
        flagImg.src = otherNext === 'de' ? '/flag-de.svg' : '/flag-en.svg';
        flagImg.alt = otherNext === 'de' ? 'Deutsch' : 'English';
        btn.setAttribute('title', flagImg.alt);
        btn.setAttribute('aria-label', flagImg.alt);
    });
    </script>
</body>
</html>
