---
import Layout from "../layouts/Layout.astro";
import { createSupabaseServerClient } from "../lib/supabase-server";

const supabase = createSupabaseServerClient(
    Astro.cookies,
    Astro.request.headers.get("Cookie") ?? "",
);
const {
    data: { user },
} = await supabase.auth.getUser();
---
<Layout>
    {!user ? (
        <main class="fm-auth-required">
            <div class="fm-auth-required-card">
                <div class="account-error">
                    You need to be logged in to use the File Manager.
                </div>
                <a href="/account?next=/filemanager" class="account-btn-link fm-auth-required-link">
                    ← Go to login
                </a>
            </div>
        </main>
    ) : (
    <main class="fm-root">
        <div id="app-screen" class="fm-app">
            <header class="fm-header">
                <h2 class="fm-header-title">File Manager</h2>
            </header>
            <section class="fm-section">
                <h3 class="fm-section-title">Upload Model</h3>
                <div class="fm-upload-area" id="drop-zone">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" class="fm-upload-icon"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg>
                    <p class="fm-upload-hint">GLB<br/><span>Drop file here or click</span></p>
                    <input type="file" id="file-input" accept=".glb" class="fm-file-input" />
                </div>
                <div id="upload-status" class="fm-upload-status" style="display:none">
                    <div class="fm-progress-row">
                        <span id="upload-filename" class="fm-progress-name"></span>
                        <span id="upload-percent" class="fm-progress-pct">0%</span>
                    </div>
                    <div class="fm-progress-bar-bg">
                        <div class="fm-progress-bar-fill" id="progress-fill" style="width:0%"></div>
                    </div>
                    <div id="upload-message" class="fm-upload-msg"></div>
                </div>
            </section>
            <section class="fm-section">
                <div class="fm-list-header">
                    <h3 class="fm-section-title" style="margin:0">Models on Server</h3>
                    <button id="refresh-btn" class="fm-btn fm-btn-secondary fm-btn-icon" title="Refresh">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                    </button>
                </div>
                <div id="model-list" class="fm-model-list">
                    <p class="fm-loading">Loading…</p>
                </div>
            </section>
        </div>
    </main>
    )}
</Layout>

<script>
function hideProgress(el: HTMLElement): void {
    el.classList.add("fm-hiding");
    el.addEventListener("animationend", () => {
        el.style.display = "none";
        el.classList.remove("fm-hiding");
    }, { once: true });
}

function formatSize(bytes: number): string {
    if (bytes > 1048576) return (bytes / 1048576).toFixed(1) + " MB";
    if (bytes > 1024) return (bytes / 1024).toFixed(0) + " KB";
    return bytes + " B";
}

const ICON_DOWNLOAD = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 15V3"/></svg>`;
const ICON_DELETE = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>`;

function showAuthError(message: string): void {
    const app = document.getElementById("app-screen");
    if (!app) return;
    app.innerHTML = `
        <div class="fm-auth-required-card" style="margin:4rem auto;max-width:420px;">
            <div class="account-error">${message}</div>
            <a href="/account?next=/filemanager" class="account-btn-link fm-auth-required-link">← Go to login</a>
        </div>
    `;
}

async function loadModels(): Promise<void> {
    const list = document.getElementById("model-list") as HTMLElement;
    list.innerHTML = '<div class="fm-list-spinner"></div>';
    const r = await fetch("/api/filemanager/models-list");
    if (r.status === 401) { showAuthError("Your session has expired. Please log in again."); return; }
    if (!r.ok) { list.innerHTML = '<p class="fm-error">Failed to load</p>'; return; }
    const models: Array<{ name: string; size: number }> = await r.json();
    if (!models.length) { list.innerHTML = '<p class="fm-empty">No models found</p>'; return; }
    list.innerHTML = "";
    models.forEach((m, i) => {
        const row = document.createElement("div");
        row.className = "fm-model-row";
        row.style.animationDelay = `${i * 50}ms`;
        row.innerHTML = `
            <div class="fm-model-main">
                <div class="fm-model-info">
                    <span class="fm-model-name">${m.name}</span>
                    <span class="fm-model-size">${formatSize(m.size)}</span>
                </div>
                <div class="fm-model-actions">
                    <button class="fm-btn fm-btn-download fm-btn-icon" data-name="${m.name}" title="Download">${ICON_DOWNLOAD}</button>
                    <button class="fm-btn fm-btn-delete fm-btn-icon" data-name="${m.name}" title="Delete">${ICON_DELETE}</button>
                </div>
            </div>
            <div class="fm-row-progress" style="display:none">
                <div class="fm-progress-row">
                    <span class="fm-progress-name fm-dl-name"></span>
                    <span class="fm-progress-pct fm-dl-pct">0%</span>
                </div>
                <div class="fm-progress-bar-bg">
                    <div class="fm-progress-bar-fill fm-progress-bar-dl fm-dl-fill" style="width:0%"></div>
                </div>
                <div class="fm-upload-msg fm-dl-msg"></div>
            </div>
        `;
        list.appendChild(row);
    });
    list.querySelectorAll<HTMLButtonElement>(".fm-btn-download").forEach(btn => {
        btn.addEventListener("click", () => {
            const row = btn.closest(".fm-model-row") as HTMLElement;
            downloadModel(btn.dataset.name!, row);
        });
    });
    list.querySelectorAll<HTMLButtonElement>(".fm-btn-delete").forEach(btn => {
        btn.addEventListener("click", () => deleteModel(btn.dataset.name!));
    });
}

async function downloadModel(name: string, row: HTMLElement): Promise<void> {
    const progressEl = row.querySelector<HTMLElement>(".fm-row-progress")!;
    const fillEl = row.querySelector<HTMLElement>(".fm-dl-fill")!;
    const pctEl = row.querySelector<HTMLElement>(".fm-dl-pct")!;
    const nameEl = row.querySelector<HTMLElement>(".fm-dl-name")!;
    const msgEl = row.querySelector<HTMLElement>(".fm-dl-msg")!;

    nameEl.textContent = "Downloading…";
    fillEl.style.width = "";
    fillEl.classList.add("fm-progress-bar-indeterminate");
    pctEl.textContent = "…";
    msgEl.textContent = "Waiting for server…";
    msgEl.className = "fm-upload-msg fm-dl-msg";
    progressEl.style.display = "block";

    const fetchUrl = `/api/filemanager/models-download?name=${encodeURIComponent(name)}`;

    const r = await fetch(fetchUrl);
    if (r.status === 401) { showAuthError("Your session has expired. Please log in again."); return; }
    if (!r.ok) {
        fillEl.classList.remove("fm-progress-bar-indeterminate");
        fillEl.style.width = "0%";
        pctEl.textContent = "0%";
        msgEl.textContent = "Download failed";
        msgEl.className = "fm-upload-msg fm-dl-msg fm-upload-msg-error";
        setTimeout(() => hideProgress(progressEl), 4000);
        return;
    }

    const contentLength = r.headers.get("content-length");
    const total = contentLength ? parseInt(contentLength, 10) : 0;
    let loaded = 0;
    const chunks: Uint8Array<ArrayBuffer>[] = [];
    const reader = r.body!.getReader();

    msgEl.textContent = total > 0
        ? `0 / ${formatSize(total)}`
        : "Receiving data…";

    while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        chunks.push(new Uint8Array(value) as Uint8Array<ArrayBuffer>);
        loaded += value.byteLength;

        if (total > 0) {
            const pct = Math.round(loaded / total * 100);
            pctEl.textContent = pct + "%";
            msgEl.textContent = `${formatSize(loaded)} / ${formatSize(total)}`;
        } else {
            msgEl.textContent = formatSize(loaded) + " received…";
        }
    }

    fillEl.classList.remove("fm-progress-bar-indeterminate");
    fillEl.style.width = "100%";
    pctEl.textContent = "100%";
    msgEl.textContent = "✓ Done";
    msgEl.className = "fm-upload-msg fm-dl-msg fm-upload-msg-ok";
    setTimeout(() => hideProgress(progressEl), 3000);

    const blob = new Blob(chunks as BlobPart[]);
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url; a.download = name; a.click();
    URL.revokeObjectURL(url);
}

async function deleteModel(name: string): Promise<void> {
    if (!confirm(`Delete "${name}"?`)) return;
    const r = await fetch(`/api/filemanager/models-delete?name=${encodeURIComponent(name)}`, { method: "DELETE" });
    if (r.status === 401) { showAuthError("Your session has expired. Please log in again."); return; }
    if (r.ok || r.status === 204) {
        loadModels();
    } else {
        alert("Delete failed. Please try again.");
    }
}

function setProgress(pct: number, msg = "", error = false, indeterminate = false): void {
    const status = document.getElementById("upload-status") as HTMLElement;
    status.style.display = "block";
    const fillEl = document.getElementById("progress-fill") as HTMLElement;
    const pctEl = document.getElementById("upload-percent") as HTMLElement;
    if (indeterminate) {
        fillEl.classList.add("fm-progress-bar-indeterminate");
        pctEl.textContent = "…";
    } else {
        fillEl.classList.remove("fm-progress-bar-indeterminate");
        fillEl.style.width = pct + "%";
        pctEl.textContent = pct + "%";
    }
    const msgEl = document.getElementById("upload-message") as HTMLElement;
    msgEl.textContent = msg;
    msgEl.className = "fm-upload-msg" + (error ? " fm-upload-msg-error" : pct === 100 && !indeterminate ? " fm-upload-msg-ok" : "");
}

async function uploadFile(file: File): Promise<void> {
    (document.getElementById("upload-filename") as HTMLElement).textContent = file.name;
    setProgress(0, "Uploading…", false, true);

    return new Promise<void>((resolve) => {
        const xhr = new XMLHttpRequest();
        const totalBytes = file.size;

        xhr.upload.addEventListener("progress", (e: ProgressEvent) => {
            if (e.lengthComputable) {
                setProgress(0, `${formatSize(e.loaded)} / ${formatSize(totalBytes)}`, false, true);
            }
        });
        xhr.upload.addEventListener("load", () => {
            setProgress(0, "Processing on server…", false, true);
        });
        xhr.addEventListener("load", () => {
            if (xhr.status === 201 || xhr.status === 200 || xhr.status === 204) {
                setProgress(100, "✓ Upload successful");
                loadModels();
                const upEl = document.getElementById("upload-status") as HTMLElement;
                setTimeout(() => hideProgress(upEl), 3000);
            } else if (xhr.status === 401) {
                const upEl2 = document.getElementById("upload-status") as HTMLElement;
                hideProgress(upEl2);
                showAuthError("Your session has expired. Please log in again.");
            } else {
                setProgress(0, `Error: ${xhr.status} ${xhr.statusText}`, true);
                const upEl3 = document.getElementById("upload-status") as HTMLElement;
                setTimeout(() => hideProgress(upEl3), 4000);
            }
            resolve();
        });
        xhr.addEventListener("error", () => {
            setProgress(0, "Network error", true);
            const upEl4 = document.getElementById("upload-status") as HTMLElement;
            setTimeout(() => hideProgress(upEl4), 4000);
            resolve();
        });

        const fd = new FormData();
        fd.append("file", file);
        xhr.open("POST", "/api/filemanager/models-upload");
        xhr.send(fd);
    });
}

document.addEventListener("DOMContentLoaded", () => {
    if (!document.getElementById("app-screen")) return;

    loadModels();

    (document.getElementById("refresh-btn") as HTMLButtonElement).addEventListener("click", loadModels);

    const dropZone = document.getElementById("drop-zone") as HTMLElement;
    const fileInput = document.getElementById("file-input") as HTMLInputElement;
    dropZone.addEventListener("click", () => fileInput.click());
    fileInput.addEventListener("change", () => {
        if (fileInput.files?.[0]) uploadFile(fileInput.files[0]);
    });
    dropZone.addEventListener("dragover", (e: DragEvent) => { e.preventDefault(); dropZone.classList.add("fm-drag-over"); });
    dropZone.addEventListener("dragleave", () => dropZone.classList.remove("fm-drag-over"));
    dropZone.addEventListener("drop", (e: DragEvent) => {
        e.preventDefault(); dropZone.classList.remove("fm-drag-over");
        const file = e.dataTransfer?.files?.[0];
        if (file) uploadFile(file);
    });
});
</script>
