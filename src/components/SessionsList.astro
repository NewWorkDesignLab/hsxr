---
const API_BASE = "https://api-gateway-00224466.ludorfjonas.workers.dev/hsxr";
---

<section class="sessions-card" aria-label="Available sessions">
    <header class="sessions-card-header">
        <div class="sessions-card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            <span>SESSIONS</span>
        </div>
        <span id="sessions-count" class="sessions-card-meta">0 sessions</span>
    </header>
    <div id="sessions-list" class="sessions-list">
        <div class="session-placeholder">
            <article class="session-item session-item-skeleton" aria-hidden="true">
                <div class="session-info">
                    <div class="skeleton skeleton-title"></div>
                    <div class="session-meta">
                        <div class="session-meta-row">
                            <div class="skeleton skeleton-label"></div>
                            <div class="skeleton skeleton-value"></div>
                        </div>
                        <div class="session-meta-row">
                            <div class="skeleton skeleton-label"></div>
                            <div class="skeleton skeleton-value"></div>
                        </div>
                    </div>
                </div>
                <div class="skeleton skeleton-btn"></div>
            </article>
            <p class="sessions-empty">Loading sessions</p>
        </div>
    </div>
</section>

<script define:vars={{ API_BASE }}>
    const REFRESH_INTERVAL_MS = 1000;
    const listEl = document.getElementById("sessions-list");
    const countEl = document.getElementById("sessions-count");

    let currentSnapshot = "";
    let inFlight = false;

    function formatDate(iso) {
        const d = new Date(iso);
        if (isNaN(d.getTime())) return iso;
        return d.toLocaleString("de-DE", {
            year: "numeric",
            month: "2-digit",
            day: "2-digit",
            hour: "2-digit",
            minute: "2-digit",
        });
    }

    function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, (c) =>
            ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]),
        );
    }

    function render(lobbies) {
        countEl.textContent = `${lobbies.length} ${lobbies.length === 1 ? "session" : "sessions"}`;

        lobbies.sort((a, b) => (a.created_at < b.created_at ? 1 : -1));

        const snapshot = JSON.stringify(lobbies);
        if (snapshot === currentSnapshot) return;
        currentSnapshot = snapshot;

        if (lobbies.length === 0) {
            listEl.innerHTML = `
                <div class="session-placeholder">
                    <article class="session-item session-item-skeleton" aria-hidden="true">
                        <div class="session-info">
                            <div class="skeleton skeleton-title"></div>
                            <div class="session-meta">
                                <div class="session-meta-row">
                                    <div class="skeleton skeleton-label"></div>
                                    <div class="skeleton skeleton-value"></div>
                                </div>
                                <div class="session-meta-row">
                                    <div class="skeleton skeleton-label"></div>
                                    <div class="skeleton skeleton-value"></div>
                                </div>
                            </div>
                        </div>
                        <div class="skeleton skeleton-btn"></div>
                    </article>
                    <p class="sessions-empty">No active sessions</p>
                </div>`;
            return;
        }

        listEl.innerHTML = lobbies
            .map(
                (l) => {
                    const playerCount = Number(l.player_count ?? 0);
                    const maxPlayers = Number(l.max_players ?? 0);
                    const isFull = maxPlayers > 0 && playerCount >= maxPlayers;
                    return `
                <article class="session-item${isFull ? " session-item-full" : ""}" data-join-code="${escapeHtml(l.join_code)}">
                    <div class="session-info">
                        <h3 class="session-title">${escapeHtml(l.join_code)}</h3>
                        <dl class="session-meta">
                            <div class="session-meta-row">
                                <dt>Created at:</dt>
                                <dd>${escapeHtml(formatDate(l.created_at))}</dd>
                            </div>
                            <div class="session-meta-row">
                                <dt>Created by:</dt>
                                <dd>${escapeHtml(l.creator)}</dd>
                            </div>
                        </dl>
                    </div>
                    <div class="session-players${isFull ? " session-players-full" : ""}" aria-label="Players">
                        <span class="session-players-current">${escapeHtml(String(playerCount))}</span>
                        <span class="session-players-sep">/</span>
                        <span class="session-players-max">${escapeHtml(String(maxPlayers))}</span>
                    </div>
                    <button type="button" class="session-qr-btn"${isFull ? " disabled aria-disabled=\"true\"" : ""} aria-label="${isFull ? `Lobby ${escapeHtml(l.join_code)} is full` : `Show QR code for ${escapeHtml(l.join_code)}`}">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <rect x="3" y="3" width="7" height="7"/>
                            <rect x="14" y="3" width="7" height="7"/>
                            <rect x="3" y="14" width="7" height="7"/>
                            <line x1="14" y1="14" x2="14" y2="14.01"/>
                            <line x1="20" y1="14" x2="20" y2="14.01"/>
                            <line x1="14" y1="20" x2="14" y2="20.01"/>
                            <line x1="20" y1="20" x2="20" y2="20.01"/>
                            <line x1="17" y1="17" x2="17" y2="17.01"/>
                        </svg>
                    </button>
                </article>`;
                },
            )
            .join("");
    }

    async function fetchSessions() {
        if (inFlight) return;
        inFlight = true;
        try {
            const res = await fetch(`${API_BASE}/lobbies`, {
                cache: "no-store",
            });
            if (!res.ok) {
                if (currentSnapshot === "") {
                    listEl.innerHTML = `<p class="sessions-empty sessions-error">Could not load sessions (HTTP ${res.status}).</p>`;
                }
                return;
            }
            const data = await res.json();
            render(Array.isArray(data) ? data : []);
        } catch (err) {
            if (currentSnapshot === "") {
                listEl.innerHTML = `<p class="sessions-empty sessions-error">Could not load sessions.</p>`;
            }
            console.warn("[sessions] fetch failed:", err);
        } finally {
            inFlight = false;
        }
    }

    listEl.addEventListener("click", (ev) => {
        const btn = ev.target.closest(".session-qr-btn");
        if (!btn || btn.disabled) return;
        const item = btn.closest(".session-item");
        const code = item && item.dataset.joinCode;
        if (!code) return;
        window.dispatchEvent(
            new CustomEvent("hsxr:show-qr", { detail: { payload: `MUESJoin_${code}` } }),
        );
    });

    fetchSessions();
    window.setInterval(fetchSessions, REFRESH_INTERVAL_MS);
</script>

