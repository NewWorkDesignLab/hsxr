---
import "../styles/global.css";
import { getOptionalUser } from "../lib/auth-helpers";

interface Props {
    hideHeaderActions?: boolean;
    hideHomeLink?: boolean;
}

const { hideHeaderActions = false, hideHomeLink = false } = Astro.props;

const currentUser = await getOptionalUser(
    Astro.cookies,
    Astro.request.headers.get("Cookie") ?? "",
);
const isAccountPage = Astro.url.pathname === "/account";
const isFilemanagerPage = Astro.url.pathname === "/filemanager";
const isHomePage = Astro.url.pathname === "/";
---

<html lang="en">
<head>
    <meta charset="utf-8"/>
    <link rel="icon" type="image/png" href="/favicon.png"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="description" content="A QR Code for joining a HoloSpace-XR Lobby."/>
    <meta name="generator" content={Astro.generator}/>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap"/>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <title>HoloSpace-XR</title>
</head>
<body>
    {!isHomePage && !hideHomeLink && (
        <a href="/" class="home-link" aria-label="Home" title="Home">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1h-5v-7H9v7H4a1 1 0 0 1-1-1V9.5z"/>
            </svg>
        </a>
    )}
    <div class="header-actions">
        {!hideHeaderActions && currentUser && !isFilemanagerPage && (
            <a href="/filemanager" class="filemanager-icon" aria-label="File Manager" title="File Manager">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
                </svg>
            </a>
        )}
        {!hideHeaderActions && currentUser ? (
            <a
                href="/account"
                class={`account-link${isAccountPage ? " account-link-active" : ""}`}
                aria-label="Account"
                title={currentUser.display_name ?? "Account"}
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                <span class="account-link-name">{currentUser.display_name ?? "Account"}</span>
            </a>
        ) : (
            !hideHeaderActions && !isAccountPage && (
                <a href="/account" class="account-link account-link-login" aria-label="Login" title="Login">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                        <polyline points="10 17 15 12 10 7"/>
                        <line x1="15" y1="12" x2="3" y2="12"/>
                    </svg>
                </a>
            )
        )}
    </div>
    <slot />
    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-logos">
                <img src="/logos/logo1.png" alt="Logo 1" class="footer-logo footer-logo-sm" />
                <img src="/logos/logo2.png" alt="Logo 2" class="footer-logo footer-logo-sm" />
                <img src="/logos/logo3.png" alt="Logo 3" class="footer-logo footer-logo-sm" />
            </div>
            <span class="footer-divider">|</span>
            <a href="https://www.fh-dresden.eu/de/forschung/forschungsprojekte/validierungsprojekt-holospacexr/" target="_blank" rel="noopener noreferrer" class="footer-details-link">Project Details</a>
            <span class="footer-divider footer-divider-secondary">|</span>
            <a href="/privacy" class="footer-details-link">Privacy Policy</a>
        </div>
    </footer>
</body>
</html>

